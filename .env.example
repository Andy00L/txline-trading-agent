# Copy to .env and fill with real values. .env is gitignored. Never commit real tokens or keypairs.

# TxLINE off-chain API. Confirmed live 2026-06-26: guest auth and data are both served
# from the txline host; the oracle-dev host did not resolve. Mainnet uses txline.txodds.com.
# sourceRef: docs/research/M0-recon-findings.md (hostnames, auth flow)
TXLINE_DATA_BASE_URL=https://txline-dev.txodds.com
TXLINE_AUTH_BASE_URL=https://txline-dev.txodds.com
TXLINE_JWT=
TXLINE_API_TOKEN=
# Free World Cup tier service level: 1 = 60s delayed, 12 = real-time. Empty leagues = standard bundle.
TXLINE_SERVICE_LEVEL=12

# Solana devnet
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Websocket endpoint for confirmations; derived from SOLANA_RPC_URL when left empty.
SOLANA_RPC_SUBSCRIPTIONS_URL=
# Path to the agent authority keypair (paper trading only; never a funded mainnet key)
AGENT_KEYPAIR_PATH=
# txoracle CPI target (devnet). sourceRef: docs/research/M0-recon-findings.md
TXORACLE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG

# Our agent_ledger program (declare_id! in programs/agent_ledger/src/lib.rs). Override only
# if you redeploy under a different program keypair.
AGENT_PROGRAM_ID=FLZiKMUaPAGMtPLbfHvHwfiVfkTZD8RZ84CSrkDy1kLD
# One ledger per strategy id; bump to start a fresh ledger.
STRATEGY_ID=0
# Compute units for the settle transaction (validate_stat CPI is heavy; 1_400_000 is the
# per-transaction max). sourceRef: docs/research/txline-onchain.md.
COMPUTE_UNIT_LIMIT=1400000
# Paper bankroll in micro-USDC (1_000_000_000 = 1000 paper USDC). Devnet, no real funds.
STARTING_BANKROLL=1000000000

# M4 devnet settle e2e target (tools/devnet/src/settle-e2e.ts). A finished World Cup
# fixture whose scores root is posted on chain, and one scores event sequence in it.
E2E_FIXTURE_ID=
E2E_SEQ=
# Optional decision parameters for the e2e demo bet (sane defaults applied when empty).
E2E_STAKE=25000000
E2E_ENTRY_ODDS_MILLI=2000
E2E_FAIR_PROB_BPS=5000
